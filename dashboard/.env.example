# dashboard/.env.example — copy to .env if you need to override defaults.
# Most operators do NOT need this file; the compose defaults are correct.

# Override the host's WordPress root if you didn't use /opt/wp.
# WP_ROOT=/opt/wp

# Optional: explicit PHP session secret. The dashboard generates a per-session
# CSRF token regardless; this env is reserved for future hardening.
# DASHBOARD_SESSION_SECRET=change-me-to-32-random-bytes
