{{domain}} {
    root * /opt/wp/sites/{{slug}}
    php_fastcgi 127.0.0.1:{{port}}

    # Defense-in-depth: block PHP execution under uploads/ (in case a
    # malicious upload bypasses WordPress's MIME sanitization).
    @uploads_php path_regexp ^/wp-content/uploads/.*\.php$
    respond @uploads_php 403

    encode gzip zstd
}
