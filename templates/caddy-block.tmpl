{{domain}} {
    # Reverse-proxy WordPress FPM at 127.0.0.1:{{port}} (loopback only).
    root * /opt/wp/sites/{{slug}}/wp-content
    php_fastcgi 127.0.0.1:{{port}}

    # Defense-in-depth: block PHP execution under uploads/.
    @forbid_uploads_php {
        path_regexp /wp-content/uploads/.*\.php$
    }
    respond @forbid_uploads_php 403

    # XML-RPC disabled (HARD-02). The wp-config filters back this up.
    respond /xmlrpc.php 403

    encode gzip zstd

    log {
        output discard
    }
}
